# Нормализация переводов строк: все текстовые файлы хранятся и выгружаются с LF.
# Снимает предупреждения "LF will be replaced by CRLF" на Windows.
* text=auto eol=lf

# Бинарные файлы — не трогать.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp3   binary
*.wav   binary
*.ogg   binary
*.mp4   binary
